<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>disable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>EnterpriseLicenseDeployer</AssemblyName>
    <RootNamespace>EnterpriseLicenseDeployer</RootNamespace>
    <ApplicationIcon></ApplicationIcon>
    <Company>Your Company</Company>
    <Product>SKY License Deployment Manager</Product>
    <Version>1.0.0</Version>
    <StartupObject>EnterpriseLicenseDeployer.Program</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
